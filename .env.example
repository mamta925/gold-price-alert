# Gold Price Alert — environment variables
# Copy to .env and fill in values. Never commit .env.

# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
# Optional; defaults to SMTP_USER
# ALERT_EMAIL_FROM=

# Twilio WhatsApp (price alerts only)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# SnapDeploy HTTP trigger
CRON_SECRET=

# Optional
# TZ=Asia/Kolkata
# LOG_LEVEL=INFO
# PORT=8000
